# Suraksha api-server — environment variables
#
# Copy this file to .env for local development, or set these in your
# deployment's secret manager (e.g. Replit Secrets). Nothing here is a real
# value — this file documents which vars exist and what happens if each one
# is missing, since that was previously scattered across individual route
# files with no single place to check.

# ── Required to start ────────────────────────────────────────────────────────
# The server refuses to boot without a port.
PORT=

# ── Required for the app to be functional (fails soft, not a crash) ──────────
# Every route that checks auth calls verifyFirebaseToken(), which needs ONE
# of these three to resolve a Firebase project — without any of them, EVERY
# authenticated route always returns 401 (the server itself still starts).
# FIREBASE_SERVICE_ACCOUNT is the full service-account JSON and is required
# for privileged operations; the other two only support ID-token verification.
FIREBASE_SERVICE_ACCOUNT=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_PROJECT_ID=

# Sakhi chat (/sakhi/chat) proxies OpenAI and needs one of these two — without
# either, importing the shared OpenAI integration package throws at startup
# (this one var, unlike the ones below, is NOT handled gracefully yet).
AI_INTEGRATIONS_OPENAI_API_KEY=
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ── Optional — each gates exactly one feature, degrades to a clear ──────────
# ── response (503/not_configured) rather than crashing the server ──────────

# Server-side account-deletion cleanup (/auth/account) and the RevenueCat
# webhook both need this. As of the SOS idempotency-cache and rate-limit
# migration (migrations/001_sos_idempotency_and_rate_limit.sql), those two
# features ALSO depend on this being set — without it, both silently fail
# open (no dedup, no rate limiting) rather than blocking SOS delivery.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Nearby police/hospital/pharmacy/shelter search (/nearby-places).
GOOGLE_PLACES_API_KEY=

# Automatic SOS/journey-start SMS via Twilio. Without these, the mobile app's
# native SMS composer fallback still works — the user just has to tap Send.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# RevenueCat subscription webhook (/revenuecat-webhook). Without this, the
# route responds 501 rather than processing (unauthenticated) webhook calls.
REVENUECAT_WEBHOOK_SECRET=

# Comma-separated list of origins allowed to call this API directly from a
# browser (e.g. a web build of the app). Requests with no Origin header
# (the native mobile app, server-to-server calls) are never affected by
# this. Leaving it unset rejects all cross-origin browser requests by
# default — set it explicitly if a web client needs direct access.
CORS_ALLOWED_ORIGINS=

# ── Optional — operational ───────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
